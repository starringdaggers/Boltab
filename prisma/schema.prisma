// Boltab Brilliant Schools — Results Portal
// Database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student?
  teacher Teacher?

  @@map("users")
}

model Student {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  admissionNo   String   @unique
  classId       String
  class         Class    @relation(fields: [classId], references: [id])
  guardianName  String?
  guardianPhone String?

  results     Result[]
  reportCards ReportCard[]

  @@map("students")
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Subjects/classes this teacher is permitted to enter results for
  assignments TeacherAssignment[]
  resultsUploaded Result[]
  reportCardsUpdated ReportCard[]

  @@map("teachers")
}

model TeacherAssignment {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId   String
  class     Class   @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
  @@map("teacher_assignments")
}

model Class {
  id   String @id @default(cuid())
  name String @unique // e.g. "JSS1", "SS2 Science"

  students    Student[]
  assignments TeacherAssignment[]
  results     Result[]

  @@map("classes")
}

model Subject {
  id   String @id @default(cuid())
  name String @unique // e.g. "Mathematics", "English Language"

  assignments TeacherAssignment[]
  results     Result[]

  @@map("subjects")
}

model Term {
  id          String   @id @default(cuid())
  name        String   // e.g. "First Term"
  academicYear String  // e.g. "2026/2027"
  isLocked    Boolean  @default(false) // admin can lock a term to stop further edits
  resultsReleased Boolean @default(false) // admin controls whether students can see results/report cards for this term at all

  results     Result[]
  reportCards ReportCard[]

  @@unique([name, academicYear])
  @@map("terms")
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId    String
  class      Class    @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  termId     String
  term       Term     @relation(fields: [termId], references: [id])

  // Continuous-assessment breakdown, mirroring the school's paper report card
  firstHalfScore       Float  @default(0)
  firstHalfObtainable  Float  @default(20)
  secondHalfScore      Float  @default(0)
  secondHalfObtainable Float  @default(20)
  examScore            Float  @default(0)
  examObtainable       Float  @default(60)

  totalScore      Float    // computed at write time: sum of the three scores above
  totalObtainable Float    @default(100)
  grade           String   // word rating computed from percentage, e.g. "Excellent", "Good"
  remark          String?  // optional teacher override/comment for this subject

  uploadedById String
  uploadedBy   Teacher @relation(fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([studentId, subjectId, termId]) // one result per student/subject/term
  @@map("results")
}

// One record per student per term — the non-subject parts of the paper
// report card: attendance, psychomotor/affective ratings, and comments.
model ReportCard {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  termId    String
  term      Term    @relation(fields: [termId], references: [id])

  // 1. Attendance
  timesSchoolOpened Int?
  timesPresent      Int?
  timesAbsent       Int?
  nextTermBegins    String?

  // 3 & 4. Psychomotor skills / affective areas — each stored as
  // { "Verbal Fluency": 5, "Games": 4, ... } with ratings 1-5
  psychomotor Json?
  affective   Json?

  generalPerformance  String?
  classTeacherName    String?
  classTeacherComment String?
  headmasterComment   String?
  dateIssued          String?

  // Admin-controlled: hides this specific student's report card/results even
  // when the term overall has been released to students.
  isWithheld Boolean @default(false)

  updatedById String?
  updatedBy   Teacher? @relation(fields: [updatedById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, termId])
  @@map("report_cards")
}
